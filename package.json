{
  "name": "banking-services",
  "version": "1.0.0",
  "description": "A banking services RCS chatbot for viewing accounts, managing cards, viewing statements, and finding ATM/branch locations",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx server.ts",
    "dev": "tsx watch server.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "keywords": [
    "rcs",
    "chatbot",
    "banking",
    "finance",
    "pinnacle"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "rcs-js": "^2.0.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "eslint": "^9.37.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
